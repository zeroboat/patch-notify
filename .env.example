# ── Django ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=False
DJANGO_ENVIRONMENT=production

# 접속을 허용할 호스트 목록 (쉼표로 구분, localhost/127.0.0.1은 자동 포함)
# 예) 내부망 IP, 도메인 등을 추가
ALLOWED_HOSTS=192.168.0.100,yourdomain.com

# ── Django 초기 관리자 계정 (최초 배포 시 자동 생성, 이후 재시작에는 무시됨) ────────────
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=changeme123!

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=patchnotify
DB_USER=patchuser
DB_PASSWORD=changeme

# ── Ollama (내부 AI 번역 서버) ────────────────────────────────────────────────
OLLAMA_HOST=http://your-ollama-server:11434
OLLAMA_MODEL=your-model-name

# ── Gmail SMTP ───────────────────────────────────────────────────────────────
# Google 계정 > 보안 > 2단계 인증 활성화 후 "앱 비밀번호" 발급
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Slack App (slack-api 서비스 — FastAPI, 포트 8001) ─────────────────────────
# https://api.slack.com/apps 에서 앱 생성 후 발급
# OAuth & Permissions > Redirect URLs 에 SLACK_REDIRECT_URI 등록
# Event Subscriptions > Request URL: https://slack-api.yourdomain.com/slack/events/
# Bot Token Scopes: chat:write, channels:read
# App Home > Home Tab 활성화
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_REDIRECT_URI=https://slack-api.yourdomain.com/slack/oauth/callback/

# ── Database URL (slack-api 로컬 테스트용) ────────────────────────────────────
# 로컬에서 SQLite를 사용할 경우 아래 주석 해제 후 경로 수정
# 운영(Docker) 환경에서는 주석 처리 — DB_HOST/DB_NAME 등으로 자동 구성됨
# DATABASE_URL=sqlite:///C:/절대경로/patch-notify/backend/db.sqlite3

# ── Notion ───────────────────────────────────────────────────────────────
# Notion 연동 사용 여부 (true/false)
NOTION_ENABLED=false
# https://www.notion.so/my-integrations 에서 Integration 생성 후 발급
NOTION_TOKEN=your-notion-integration-token

# ── Nextcloud (파일 이중 저장 — NAS) ──────────────────────────────────────
# Nextcloud 연동 사용 여부 (true/false) — 활성화 시 Notion MD 파일을 NAS에 이중 저장
NEXTCLOUD_ENABLED=false
# Nextcloud 서버 URL (예: https://cloud.example.com)
NEXTCLOUD_URL=https://nas.example.com
# Nextcloud 계정 (앱 비밀번호 사용 권장: 설정 > 보안 > 앱 비밀번호)
NEXTCLOUD_USER=your-nextcloud-user
NEXTCLOUD_PASSWORD=your-app-password
# Nextcloud 내 업로드 경로 (Nextcloud 루트 기준)
NEXTCLOUD_UPLOAD_PATH=/PatchFiles
